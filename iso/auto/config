#!/bin/bash
set -e
cd "$(dirname "$0")/.."

# Fetch Google Chrome signing key (ASCII-armored) for chrome.list.chroot.
if [ ! -s config/archives/chrome.key.chroot ]; then
    echo "Fetching Google Chrome signing key..."
    curl -fsSL https://dl.google.com/linux/linux_signing_key.pub -o config/archives/chrome.key.chroot
fi

# Base: Debian sid (no -security/-updates pockets). Performance: mitigations=off always.
lb config noauto     --distribution sid     --debian-installer none     --archive-areas "main contrib non-free non-free-firmware"     --apt-recommends false     --apt-indices false     --binary-images iso-hybrid     --bootloaders "grub-efi,syslinux"     --uefi-secure-boot disable     --linux-packages none     --linux-flavours "7.0.10-skillfishos"     --memtest none     --firmware-chroot true     --firmware-binary true     --mirror-bootstrap "http://deb.debian.org/debian/"     --mirror-chroot "http://deb.debian.org/debian/"     --mirror-binary "http://deb.debian.org/debian/"     --security false     --updates false     --backports false     --bootappend-live "boot=live components mitigations=off"     --image-name "SkillFishOS"     "${@}"
