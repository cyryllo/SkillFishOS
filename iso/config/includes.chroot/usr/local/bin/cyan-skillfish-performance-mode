#!/usr/bin/env bash
case "${1:---status}" in
  --on|on)
    for f in /sys/class/drm/card*/device/power_dpm_force_performance_level; do [ -w "$f" ] && echo high >"$f" || true; done
    ;;
  --off|off)
    for f in /sys/class/drm/card*/device/power_dpm_force_performance_level; do [ -w "$f" ] && echo auto >"$f" || true; done
    ;;
  --status|status|*)
    for f in /sys/class/drm/card*/device/power_dpm_force_performance_level; do echo "$f: $(cat "$f" 2>/dev/null || true)"; done
    ;;
esac
