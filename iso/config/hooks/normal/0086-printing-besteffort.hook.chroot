#!/bin/bash
# These are frequently absent from Debian testing; install if available, never abort.
echo "[printing] best-effort extra drivers"
apt-get update >/dev/null 2>&1 || true
for p in hplip printer-driver-gutenprint printer-driver-all; do
    if apt-get install -y --no-install-recommends "$p" 2>/dev/null; then
        echo "  installed $p"
    else
        echo "  skipped $p (no candidate in forky)"
    fi
done
true
