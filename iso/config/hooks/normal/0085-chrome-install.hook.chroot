#!/bin/bash
set -e
echo "[chrome] installing google-chrome-stable from direct .deb"
cd /tmp
curl -fsSL -o google-chrome.deb \
    https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb
apt-get install -y --no-install-recommends ./google-chrome.deb \
    || { dpkg -i google-chrome.deb || true; apt-get -f install -y; }
rm -f google-chrome.deb
echo "[chrome] installed: $(dpkg-query -W -f='${Version}' google-chrome-stable 2>/dev/null || echo '??')"
