#!/bin/bash
# grub-btrfs is not packaged in Debian -> install from source (Antynea/grub-btrfs).
echo "[grub-btrfs] installing from source"
TMP=$(mktemp -d); cd "$TMP"
if git clone --depth 1 https://github.com/Antynea/grub-btrfs.git; then
    cd grub-btrfs
    make install && echo "[grub-btrfs] installed" || echo "[grub-btrfs] make install failed (non-fatal)"
    systemctl enable grub-btrfsd 2>/dev/null || true
else
    echo "[grub-btrfs] clone failed (non-fatal)"
fi
cd /; rm -rf "$TMP"
true
