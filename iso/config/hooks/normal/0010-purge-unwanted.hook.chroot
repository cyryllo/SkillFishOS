#!/bin/bash
set -e

# CLAUDE.md: no Firefox, no LibreOffice, no task-*-desktop metapackages
apt-get purge -y --auto-remove     firefox-esr firefox     libreoffice*     thunderbird     2>/dev/null || true

# Remove any accidentally-pulled task metapackages
for pkg in $(dpkg -l 'task-*' 2>/dev/null | awk '/^ii/{print $2}'); do
    apt-get purge -y --auto-remove "$pkg" 2>/dev/null || true
done

apt-get autoremove -y --purge 2>/dev/null || true
apt-get clean
