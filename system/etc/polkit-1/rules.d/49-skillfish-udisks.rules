// SkillFishOS: consenti agli utenti admin (gruppo sudo) di montare immagini disco
// (loop-setup + mount/unmount) via udisks2 senza prompt, in qualsiasi contesto.
polkit.addRule(function(action, subject) {
    if ((action.id == "org.freedesktop.udisks2.loop-setup" ||
         action.id == "org.freedesktop.udisks2.loop-delete" ||
         action.id.indexOf("org.freedesktop.udisks2.filesystem-mount") == 0) &&
        subject.isInGroup("sudo")) {
        return polkit.Result.YES;
    }
});
