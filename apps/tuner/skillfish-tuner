}


class Daemon:
    """Helper root persistente via pkexec: 1 sola autenticazione all'avvio."""
    def __init__(self):
        self.proc = None
    def start(self):
        try:
            self.proc = subprocess.Popen(["pkexec", HELPER], stdin=subprocess.PIPE,
                                         stdout=subprocess.PIPE, text=True, bufsize=1)
        except Exception:
            return False
        line = self.proc.stdout.readline()      # riga "ready" (dopo l'auth)
        try:
            return json.loads(line).get("ready", False)
        except Exception:
            return False
    def cmd(self, **kw):
        if not self.proc or self.proc.poll() is not None:
            return {"ok": False, "err": "daemon non attivo"}
        try:
            self.proc.stdin.write(json.dumps(kw) + "\n"); self.proc.stdin.flush()
            return json.loads(self.proc.stdout.readline())
        except Exception as e:
            return {"ok": False, "err": str(e)}
    def stop(self):
        try:
            if self.proc and self.proc.poll() is None:
                self.proc.stdin.write('{"cmd":"quit"}\n'); self.proc.stdin.flush()
        except Exception:
            pass


class CmdThread(QThread):
    """Esegue una funzione bloccante (benchmark) fuori dal thread UI."""
    done = pyqtSignal(object)
    def __init__(self, fn):
        super().__init__(); self.fn = fn
    def run(self):
        self.done.emit(self.fn())


class Stepper(QWidget):
    """[-] [slider] [+] [valore] — incremento fine ±1 sui pulsanti."""
    def __init__(self, lo, hi, val, unit):
        super().__init__()
        self.lo, self.hi, self.unit = lo, hi, unit
        h = QHBoxLayout(self); h.setContentsMargins(0, 0, 0, 0); h.setSpacing(6)
        self.minus = QToolButton(); self.minus.setText("−")
        self.s = QSlider(Qt.Orientation.Horizontal); self.s.setRange(lo, hi); self.s.setValue(int(val))
        self.s.setMinimumWidth(170)
        self.plus = QToolButton(); self.plus.setText("+")
        self.lbl = QLabel(); self.lbl.setMinimumWidth(96)
        self.lbl.setAlignment(Qt.AlignmentFlag.AlignRight | Qt.AlignmentFlag.AlignVCenter)
        self.lbl.setStyleSheet("color:#d8a849;font-weight:bold;")
        h.addWidget(self.minus); h.addWidget(self.s); h.addWidget(self.plus); h.addWidget(self.lbl)
        self.minus.clicked.connect(lambda: self.s.setValue(max(lo, self.s.value() - 1)))
        self.plus.clicked.connect(lambda: self.s.setValue(min(hi, self.s.value() + 1)))
        self.s.valueChanged.connect(self._upd); self._upd(int(val))
    def _upd(self, v):
        self.lbl.setText(f"{v} {self.unit}".strip())
    def value(self):
        return self.s.value()


class TunerWindow(QMainWindow):
    def __init__(self, daemon):
        super().__init__()
        self.d = daemon
        self.setWindowTitle("SkillFishOS Tuner")
        self.setWindowIcon(QIcon(ICON))
        self.resize(640, 820)
        self.cfg = (self.d.cmd(cmd="get").get("data")) or {}
        self._threads = []

        scroll = QScrollArea(); scroll.setWidgetResizable(True)
        body = QWidget(); self.box = QVBoxLayout(body)
        self.box.setContentsMargins(16, 16, 16, 16); self.box.setSpacing(14)
        scroll.setWidget(body); self.setCentralWidget(scroll)
        self.statusBar()

        self.box.addWidget(self._presets())
        self.box.addWidget(self._cpu())
        self.box.addWidget(self._gpu())
        self.box.addWidget(self._cu())
        self.box.addWidget(self._fan())
        self.box.addWidget(self._vram())
        self.box.addStretch(1)

    # ---------- helpers UI ----------
    def toast(self, msg, secs=4):
        self.statusBar().showMessage(msg, secs * 1000)

    def _help_btn(self, key):
        b = QToolButton(); b.setText("?"); b.setToolTip("Aiuto")
        def show():
            title, body = HELP.get(key, ("Aiuto", ""))
            QMessageBox.information(self, title, body)
        b.clicked.connect(show); return b

    def _row(self, title, widget, helpkey=None):
        w = QWidget(); h = QHBoxLayout(w); h.setContentsMargins(0, 0, 0, 0); h.setSpacing(8)
        lab = QLabel(title)
        h.addWidget(lab)
        if helpkey:
            h.addWidget(self._help_btn(helpkey))
        h.addStretch(1)
        h.addWidget(widget)
        return w

    def _btns(self, *items):
        w = QWidget(); h = QHBoxLayout(w); h.setContentsMargins(0, 6, 0, 0); h.addStretch(1)
        for label, cb, primary in items:
            b = QPushButton(label)
            if primary:
                b.setDefault(True)
            b.clicked.connect(cb)
            h.addWidget(b)
        return w

    def _section(self, title):
        g = QGroupBox(title); v = QVBoxLayout(g); v.setSpacing(8)
        return g, v

    def _run_async(self, fn, on_done, busy_msg):
        self.toast(busy_msg, 60)
        t = CmdThread(fn)
        t.done.connect(lambda res, th=t: (on_done(res), self._threads.remove(th) if th in self._threads else None))
        self._threads.append(t); t.start()

    # ---------- PRESET ----------
    def _presets(self):
        g, v = self._section("Preset")
        try:
            data = json.load(open(PRESETS))["presets"]
        except Exception:
            data = []
        for p in data:
            w = QWidget(); h = QHBoxLayout(w); h.setContentsMargins(0, 0, 0, 0)
            col = QVBoxLayout(); col.setSpacing(0)
            name = QLabel(p["name"]); name.setStyleSheet("font-weight:bold;")
            desc = QLabel(p.get("desc", "")); desc.setStyleSheet("color:#b9a07a;font-size:11px;")
            col.addWidget(name); col.addWidget(desc)
            h.addLayout(col); h.addStretch(1)
            b = QPushButton("Applica"); b.clicked.connect(lambda _=False, pr=p: self._apply_preset(pr))
            h.addWidget(b); v.addWidget(w)
        return g

    def _apply_preset(self, p):
        c = p["cpu"]; self.d.cmd(cmd="apply-cpu", mhz=c["frequency"], scale=c["scale"], temp=c["max_temperature"])
        gg = p["gpu"]; self.d.cmd(cmd="apply-gpu", minmhz=gg["min_mhz"], minmv=gg["min_mv"], maxmhz=gg["max_mhz"], maxmv=gg["max_mv"])
        f = p["fan"]; self.d.cmd(cmd="apply-fan", mode=f["mode"], pct=f.get("pct", 50))
        if p.get("thermal_guard"):
            self.d.cmd(cmd="thermal-guard", limit=p["thermal_guard"])
        self.toast(f"Preset «{p['name']}» applicato")

    # ---------- CPU ----------
    def _cpu(self):
        g, v = self._section("CPU"); cpu = self.cfg.get("cpu", {})
        self.cf = Stepper(3500, 4500, cpu.get("frequency", 3700), "MHz")
        self.cs = Stepper(-50, 0, cpu.get("scale", 0), "")
        self.ct = Stepper(60, 95, cpu.get("max_temperature", 85), "°C")
        v.addWidget(self._row("Frequenza massima", self.cf, "cpu_freq"))
        v.addWidget(self._row("Undervolt", self.cs, "cpu_scale"))
        v.addWidget(self._row("Limite temperatura", self.ct, "cpu_temp"))
        vals = lambda: (self.cf.value(), self.cs.value(), self.ct.value())
        v.addWidget(self._btns(
            ("Suggerisci UV", lambda: self._suggest_uv(self.cf.value()), False),
            ("Test (benchmark)", lambda: self._test_cpu(*vals()), False),
            ("Applica", lambda: (self.d.cmd(cmd="apply-cpu", mhz=vals()[0], scale=vals()[1], temp=vals()[2]), self.toast("CPU applicata")), True),
            ("Salva al boot", lambda: (self.d.cmd(cmd="persist-cpu", mhz=vals()[0], scale=vals()[1], temp=vals()[2]), self.toast("CPU salvata al boot")), False),
        ))
        return g

    def _suggest_uv(self, mhz):
        self._run_async(lambda: self.d.cmd(cmd="suggest-uv", mhz=mhz), self._uv_done,
                        f"Cerco l'undervolt ottimale per {mhz} MHz (può durare ~1 min)…")
    def _uv_done(self, r):
        s = r.get("suggested_scale", 0); self.cs.s.setValue(s)
        self.toast(f"Undervolt suggerito per {r.get('mhz',0)} MHz: scale {s} (impostato, premi Applica)", 6)
    def _test_cpu(self, mhz, scale, tmp):
        self._run_async(lambda: self.d.cmd(cmd="test-cpu", mhz=mhz, scale=scale, temp=tmp),
                        self._cpu_done, "Test CPU: applico e benchmark 60s (per temp realistica)…")
    def _cpu_done(self, r):
        if r.get("ok"):
            b = r["bench"]; self.toast(f"✓ CPU OK e applicata — {b['score']} {b['unit']}, {b['temp']}°C", 6)
        else:
            self.toast(f"✗ {r.get('err','test fallito')}", 7)

    # ---------- GPU ----------
    def _gpu(self):
        g, v = self._section("GPU"); gp = self.cfg.get("gpu", {})
        self.gf = Stepper(350, 2230, gp.get("max_mhz", 2230), "MHz")
        self.gv = Stepper(700, 1129, gp.get("max_mv", 1000), "mV")
        v.addWidget(self._row("Frequenza massima", self.gf, "gpu_freq"))
        v.addWidget(self._row("Voltaggio massimo", self.gv, "gpu_volt"))
        vals = lambda: (self.gf.value(), self.gv.value())
        v.addWidget(self._btns(
            ("Test (benchmark)", lambda: self._test_gpu(*vals()), False),
            ("Applica", lambda: (self.d.cmd(cmd="apply-gpu", minmhz=350, minmv=700, maxmhz=vals()[0], maxmv=vals()[1]), self.toast("GPU applicata")), True),
        ))
        return g

    def _test_gpu(self, maxf, maxv):
        self._run_async(lambda: self.d.cmd(cmd="test-gpu", minmhz=350, minmv=700, maxmhz=maxf, maxmv=maxv),
                        self._gpu_done, "Test GPU: applico e avvio vkpeak…")
    def _gpu_done(self, r):
        if r.get("ok"):
            b = r["bench"]; self.toast(f"✓ GPU OK e applicata — {b['score']} {b['unit']}, {b['temp']}°C", 6)
        else:
            self.toast(f"✗ {r.get('err','test fallito')}", 7)

    # ---------- COMPUTE UNIT ----------
    def _cu(self):
        g, v = self._section("Compute Unit (CU)")
        cu = self.cfg.get("cu", {}); active = cu.get("active", 0)
        sub = (f"Attive ora: {active} CU — il cambio richiede il riavvio" if active
               else "40 CU sbloccate (24 di default) — il cambio richiede il riavvio")
        self.cu_switch = QCheckBox("Sblocca 40 CU"); self.cu_switch.setChecked(bool(cu.get("unlocked")))
        v.addWidget(self._row("", self.cu_switch, "cu"))
        sl = QLabel(sub); sl.setStyleSheet("color:#b9a07a;font-size:11px;"); v.addWidget(sl)
        v.addWidget(self._btns(("Applica (riavvio)", self._set_cu, True)))
        return g

    def _set_cu(self):
        unlock = self.cu_switch.isChecked()
        heading = "Sbloccare 40 CU?" if unlock else "Tornare a 24 CU?"
        body = (("Attiva tutte le 40 Compute Unit della GPU (più potenza, più calore e consumo). " if unlock
                 else "Disattiva lo sblocco: la GPU userà 24 CU (default). ")
                + "Modifica il parametro di avvio (GRUB) e richiede un RIAVVIO per avere effetto.")
        if QMessageBox.question(self, heading, body) != QMessageBox.StandardButton.Yes:
            return
        res = self.d.cmd(cmd="set-cu", unlock=unlock)
        if res.get("ok"):
            self.toast(("40 CU sbloccate" if unlock else "24 CU ripristinate") + " — riavvia per applicare", 6)
        else:
            self.toast(f"Errore: {res.get('err','update-grub fallito')}", 7)

    # ---------- VENTOLA ----------
    def _fan(self):
        g, v = self._section("Ventola"); fan = self.cfg.get("fan", {})
        self.fan_manual = QCheckBox("Controllo manuale (off = curva automatica)")
        self.fan_manual.setChecked(fan.get("mode") == "manual")
        v.addWidget(self.fan_manual)
        self.fp = Stepper(20, 100, fan.get("pct", 50), "%")
        v.addWidget(self._row("Velocità", self.fp, "fan"))
        v.addWidget(self._btns(
            ("Test", lambda: self._test_fan(self.fp.value()), False),
            ("Applica", self._apply_fan, True),
        ))
        return g

    def _apply_fan(self):
        mode = "manual" if self.fan_manual.isChecked() else "auto"
        r = self.d.cmd(cmd="apply-fan", mode=mode, pct=self.fp.value())
        self.toast(f"Ventola: {r.get('rpm',0)} RPM" if r.get("ok") else "Errore ventola")
    def _test_fan(self, pct):
        self._run_async(lambda: self.d.cmd(cmd="apply-fan", mode="manual", pct=pct),
                        lambda r: self.toast(f"Ventola al {pct}%: {r.get('rpm',0)} RPM"),
                        f"Test ventola al {pct}%…")

    # ---------- VRAM ----------
    def _vram(self):
        g, v = self._section("VRAM"); cur = self.cfg.get("vram", {}).get("uma_mb", 0)
        info = QLabel(f"Allocazione attuale: {cur} MB ({cur/1024.0:.1f} GB)")
        info.setStyleSheet("color:#d8a849;font-weight:bold;")
        hh = QHBoxLayout(); hw = QWidget(); hw.setLayout(hh); hh.setContentsMargins(0, 0, 0, 0)
        hh.addWidget(info); hh.addWidget(self._help_btn("vram")); hh.addStretch(1)
        v.addWidget(hw)
        self.vv = [2048, 3072, 4096, 6144, 8192, 10240, 12288]
        self.vram_combo = QComboBox()
        for mb in self.vv:
            self.vram_combo.addItem(f"{mb} MB ({mb/1024.0:.0f} GB)")
        try:
            self.vram_combo.setCurrentIndex(self.vv.index(cur))
        except Exception:
            self.vram_combo.setCurrentIndex(4)
        v.addWidget(self._row("Nuova allocazione", self.vram_combo))
        v.addWidget(self._btns(("Imposta (riavvio)", self._set_vram, False)))
        return g

    def _set_vram(self):
        mb = self.vv[self.vram_combo.currentIndex()]
        if QMessageBox.question(self, f"VRAM a {mb} MB?",
                                "Scrive nel CMOS del BIOS. Serve un riavvio per applicare.") != QMessageBox.StandardButton.Yes:
            return
        self.d.cmd(cmd="set-vram", mb=mb); self.toast(f"VRAM {mb} MB — riavvia")

    def closeEvent(self, e):
        self.d.stop(); e.accept()


def main():
    app = QApplication(sys.argv)
    app.setApplicationName("SkillFishOS Tuner")
    app.setDesktopFileName("os.skillfish.Tuner")
    app.setWindowIcon(QIcon(ICON))
    daemon = Daemon()
    if not daemon.start():
        QMessageBox.critical(None, "SkillFishOS Tuner",
                             "Autenticazione annullata o helper non avviato.\n"
                             "Riavvia il programma e autorizza l'operazione.")
        sys.exit(1)
    w = TunerWindow(daemon); w.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
