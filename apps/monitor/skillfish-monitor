#!/usr/bin/env python3
# SkillFishOS Monitor v2 - live sensor dashboard + benchmark recorder/analyzer.
# Live mode: temperature, load (CPU/GPU), frequency, power (W), GPU voltage, fan.
#   Selectable refresh (0.3/0.5/0.75/1/2 s). Records to a .sfmon file (CSV-backed).
# Viewer mode: `skillfish-monitor file.sfmon` loads a recording and shows the whole
#   run with a time scrubber to analyze it second by second.
# KDE-native PyQt6, brass/steampunk look. Bilingual (IT/EN/PL). Sensors via skillfish-hud-val.
import sys, os, re, signal, subprocess, collections, csv, time, datetime, shutil
from PyQt6.QtCore import Qt, QThread, QTimer, pyqtSignal
from PyQt6.QtGui import (QIcon, QPainter, QColor, QPen, QBrush, QLinearGradient, QPainterPath, QFont)
from PyQt6.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
                             QGridLayout, QLabel, QComboBox, QPushButton, QMessageBox, QSlider,
                             QFileDialog)

ICON = "/usr/share/icons/hicolor/256x256/apps/skillfishos.png"
REC_DIR = os.path.expanduser("~/SkillFishOS-benchmarks")
SFMON_EXT = ".sfmon"

def _detect_lang():
    val = (os.environ.get("LC_ALL") or os.environ.get("LC_MESSAGES")
           or os.environ.get("LANG") or os.environ.get("LANGUAGE") or "")
    v = val.lower()
    if v.startswith("it"): return "it"
    if v.startswith("pl"): return "pl"
    return "en"
LANG = _detect_lang()
