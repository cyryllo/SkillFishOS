def load_conf():
    try:
        with open(CONF) as f:
            c = json.load(f)
        for k, v in DEFAULT_CONF.items():
            c.setdefault(k, v)
        return c
    except Exception:
        return dict(DEFAULT_CONF)


def get_secret():
    try:
        with open(SECRET_F, "rb") as f:
            return f.read()
    except Exception:
        s = os.urandom(32)
        try:
            os.makedirs(STATE, exist_ok=True)
            fd = os.open(SECRET_F, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
            os.write(fd, s); os.close(fd)
        except Exception:
            pass
        return s


