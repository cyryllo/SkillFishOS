    "Turn off": "Wyłącz",
    "Turn on": "Włącz",
    "● On": "● Włączona",
    "○ Off": "○ Wyłączona",
    "  · at boot: ": "  · przy starcie: ",
    "Log in with user “%s” password.": "Zaloguj się hasłem użytkownika „%s”.",
}
def L(it, en):
    if LANG == "it": return it
    if LANG == "pl": return PL.get(en, en)
    return en

# id, icon, name, ready?  (not-ready modules need external tools still to be wired)
MODULES = [
    ("telemetry", "📊", L("Telemetria", "Telemetry"), True),
    ("status", "🧊", L("Stato sistema", "System status"), True),
    ("tuner", "🎛️", L("Controlli", "Controls"), True),
    ("hub", "📦", L("App e pacchetti", "Apps & packages"), True),
    ("logs", "📜", "Log", True),
    ("launcher", "🚀", L("Avvio app", "Launcher"), True),
    ("kvm", "🖥️", L("Desktop (KVM)", "Desktop (KVM)"), True),
    ("terminal", "⌨️", L("Terminale", "Terminal"), True),
    ("ai", "🧠", "AI / OpenWebUI", True),
    ("gamestream", "🎮", "Game streaming", False),
    ("aiops", "🩺", "AI-Ops", True),
    ("rules", "⚙️", L("Regole auto", "Auto rules"), True),
    ("wol", "🔋", L("Power schedule", "Power schedule"), True),
    ("zerotier", "🌐", "ZeroTier", True),
]

CSS = """
QWidget{background:#0d0b06;color:#cbb98f;font-size:13px}
QLabel#brand{font-size:20px;font-weight:800}
QLabel#sub{color:#a9967a}
QLabel.gl{color:#a9967a;font-size:11px;letter-spacing:1px}
QFrame.card{background:#1a140b;border:1px solid rgba(216,168,73,.18);border-radius:14px}
QPushButton{background:#241b10;border:1px solid rgba(216,168,73,.25);border-radius:9px;color:#e8c878;
            padding:7px 14px;font-weight:600}
QPushButton:hover{border-color:#d8a849;background:rgba(216,168,73,.16)}
QPushButton#master{font-size:15px;padding:11px 22px}
QPushButton#master[on="1"]{background:#2f5d2f;border-color:#5fd24f;color:#dfffd6}
QPushButton#master[on="0"]{background:#5a2018;border-color:#e0553c;color:#f6d0c4}
