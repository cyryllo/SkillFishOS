---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import DocsShell from '../../../components/DocsShell.astro';

export async function getStaticPaths() {
  const all = await getCollection('docs');
  const entries = all.filter((e) => e.id.startsWith('en/'));
  return entries.map((entry) => ({
    params: { slug: entry.id.slice(3) },
    props: { entry, entries },
  }));
}

const { entry, entries } = Astro.props;
const { Content, headings } = await render(entry);
const slug = entry.id.slice(3);
const sidebar = entries.map((e) => ({ id: e.id.slice(3), data: e.data }));
---
<Base lang="en" page={`/docs/${slug}`} title={`${entry.data.title} — SkillFishOs Documentation`} description={entry.data.description}>
  <DocsShell lang="en" entries={sidebar} current={slug} headings={headings}>
    <Content />
  </DocsShell>
</Base>
