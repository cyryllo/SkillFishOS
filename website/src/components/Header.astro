---
import { t, localePath, SITE, type Lang } from '../i18n';
interface Props { lang: Lang; page?: string; }
const { lang, page = '/' } = Astro.props;
const home = localePath('/', lang);
const active = (p: string) => (page === p || (p === '/docs' && page.startsWith('/docs')) ? 'active' : '');
---
<header>
  <div class="wrap nav">
    <a class="logo" href={home}><img src="/img/logo.png" alt="SkillFishOs"/><span class="brandfont">SkillFish<span class="gold-text">Os</span></span></a>
    <nav class="navlinks">
      <a href={`${home}#funzioni`}>{t('nav.feat', lang)}</a>
      <a href={localePath('/gallery', lang)} class={active('/gallery')}>{t('nav.gallery', lang)}</a>
      <a href={localePath('/hardware', lang)} class={active('/hardware')}>{t('nav.hw', lang)}</a>
      <a href={localePath('/docs', lang)} class={active('/docs')}>{t('nav.docs', lang)}</a>
      <a href={localePath('/download', lang)} class={active('/download')}>{t('nav.download', lang)}</a>
      <a href={localePath('/contact', lang)} class={active('/contact')}>{t('nav.contact', lang)}</a>
      <a href={SITE.github} target="_blank" rel="noopener">GitHub ↗</a>
    </nav>
    <div class="lang">
      <a class={`lang-btn ${lang === 'it' ? 'active' : ''}`} href={localePath(page, 'it')}>IT</a>
      <a class={`lang-btn ${lang === 'en' ? 'active' : ''}`} href={localePath(page, 'en')}>EN</a>
    </div>
  </div>
</header>
