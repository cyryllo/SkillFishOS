---
import { t, type Lang } from '../i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const shots = [
  { img: 'desktop.jpg', t: 'gal.desktop.t', d: 'gal.desktop.d' },
  { img: 'tuner.jpg', t: 'gal.tuner.t', d: 'gal.tuner.d' },
  { img: 'tuner-controls.jpg', t: 'gal.tunerctl.t', d: 'gal.tunerctl.d' },
  { img: 'monitor.jpg', t: 'gal.monitor.t', d: 'gal.monitor.d' },
  { img: 'cu-test.jpg', t: 'gal.cutest.t', d: 'gal.cutest.d' },
  { img: 'ai-panel.jpg', t: 'gal.ai.t', d: 'gal.ai.d' },
  { img: 'emudeck.jpg', t: 'gal.emudeck.t', d: 'gal.emudeck.d' },
  { img: 'esde-favorites.jpg', t: 'gal.esde1.t', d: 'gal.esde1.d' },
  { img: 'benchmarks/wukong-112fps.jpg', t: 'gal.wukong.t', d: 'gal.wukong.d' },
  { img: 'benchmarks/superposition-high.jpg', t: 'gal.super.t', d: 'gal.super.d' },
  { img: 'benchmarks/heaven-113fps.jpg', t: 'gal.heaven.t', d: 'gal.heaven.d' },
  { img: 'bench-vs-bazzite.png', t: 'gal.b1.t', d: 'gal.b1.d' },
  { img: 'bench-vs-rx6600.png', t: 'gal.b2.t', d: 'gal.b2.d' },
  { img: 'about.jpg', t: 'gal.about.t', d: 'gal.about.d' },
  { img: 'boot/plymouth-splash.png', t: 'gal.boot.t', d: 'gal.boot.d' },
];
---
<section class="hero" style="padding-bottom:30px">
  <div class="wrap">
    <div class="soon"><span class="dot"></span><span>{t('gal.eye', lang)}</span></div>
    <h1 style="font-size:clamp(2rem,5vw,3.4rem)">{t('gal.h2', lang)}</h1>
    <p class="sub">{t('gal.sub', lang)}</p>
  </div>
</section>

<section class="showcase" style="padding-top:20px">
  <div class="wrap">
    <div class="gallery-grid">
      {shots.map((s, i) => (
        <figure class="ga-card">
          <button class="ga-trigger" type="button" data-idx={i} aria-label={t(s.t, lang)}>
            <img src={`/img/${s.img}`} alt={t(s.t, lang)} loading="lazy" />
            <span class="ga-zoom" aria-hidden="true">⤢</span>
          </button>
          <figcaption>
            <h3>{t(s.t, lang)}</h3>
            <p>{t(s.d, lang)}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<div id="lightbox" class="lightbox" hidden aria-hidden="true" role="dialog" aria-modal="true">
  <button class="lb-btn lb-close" type="button" aria-label="Close">×</button>
  <button class="lb-btn lb-prev" type="button" aria-label="Previous">‹</button>
  <figure class="lb-stage">
    <img class="lb-img" src="" alt="" />
    <figcaption class="lb-cap"></figcaption>
  </figure>
  <button class="lb-btn lb-next" type="button" aria-label="Next">›</button>
</div>

<style>
  .ga-trigger {
    display: block; width: 100%; padding: 0; margin: 0; border: 0;
    background: none; cursor: zoom-in; position: relative; line-height: 0;
  }
  .ga-trigger img { width: 100%; display: block; }
  .ga-zoom {
    position: absolute; top: 10px; right: 10px; width: 34px; height: 34px;
    display: grid; place-items: center; border-radius: 8px; font-size: 18px;
    color: #f4e2b8; background: rgba(20,16,10,.55);
    border: 1px solid rgba(212,175,110,.5); opacity: 0;
    transition: opacity .18s ease, transform .18s ease; backdrop-filter: blur(2px);
  }
  .ga-trigger:hover .ga-zoom, .ga-trigger:focus-visible .ga-zoom { opacity: 1; transform: scale(1.05); }
  .ga-trigger:focus-visible { outline: 2px solid #d4af6e; outline-offset: 3px; }

  .lightbox {
    position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center;
    justify-content: center; padding: clamp(12px, 3vw, 48px);
    background: rgba(8, 6, 4, .92); backdrop-filter: blur(6px);
    opacity: 0; transition: opacity .2s ease;
  }
  .lightbox[hidden] { display: none; }
  .lightbox.is-open { opacity: 1; }
  .lb-stage { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 14px; max-width: 100%; }
  .lb-img {
    max-width: min(1200px, 92vw); max-height: 82vh; width: auto; height: auto;
    border-radius: 12px; box-shadow: 0 24px 70px rgba(0,0,0,.6);
    border: 1px solid rgba(212,175,110,.35); object-fit: contain;
  }
  .lb-cap {
    color: #f4e2b8; font-size: .98rem; text-align: center; max-width: 80ch;
    text-shadow: 0 1px 4px rgba(0,0,0,.7);
  }
  .lb-btn {
    position: absolute; background: rgba(28, 22, 14, .7); color: #f4e2b8;
    border: 1px solid rgba(212,175,110,.5); border-radius: 50%;
    width: 52px; height: 52px; font-size: 30px; line-height: 1; cursor: pointer;
    display: grid; place-items: center; transition: background .15s ease, transform .15s ease;
  }
  .lb-btn:hover { background: rgba(212,175,110,.25); transform: scale(1.06); }
  .lb-close { top: 18px; right: 22px; font-size: 34px; }
  .lb-prev { left: clamp(8px, 2vw, 28px); top: 50%; transform: translateY(-50%); }
  .lb-next { right: clamp(8px, 2vw, 28px); top: 50%; transform: translateY(-50%); }
  .lb-prev:hover, .lb-next:hover { transform: translateY(-50%) scale(1.06); }
  @media (max-width: 560px) {
    .lb-prev { left: 6px; } .lb-next { right: 6px; }
    .lb-btn { width: 44px; height: 44px; font-size: 26px; }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  if (lb) {
    const lbImg = lb.querySelector('.lb-img') as HTMLImageElement;
    const lbCap = lb.querySelector('.lb-cap') as HTMLElement;
    const triggers = Array.from(document.querySelectorAll('.ga-trigger')) as HTMLButtonElement[];
    const items = triggers.map((tr) => {
      const fig = tr.closest('figure');
      const img = tr.querySelector('img') as HTMLImageElement;
      const h3 = fig?.querySelector('figcaption h3');
      const p = fig?.querySelector('figcaption p');
      return {
        src: img?.currentSrc || img?.src || '',
        alt: img?.alt || '',
        cap: [h3?.textContent, p?.textContent].filter(Boolean).join(' — '),
      };
    });
    let idx = 0;

    const render = () => {
      const it = items[idx];
      lbImg.src = it.src;
      lbImg.alt = it.alt;
      lbCap.textContent = it.cap;
    };
    const open = (i: number) => {
      idx = i; render();
      lb.hidden = false; lb.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(() => lb.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      lb.classList.remove('is-open'); lb.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setTimeout(() => { lb.hidden = true; }, 200);
    };
    const step = (n: number) => { idx = (idx + n + items.length) % items.length; render(); };

    triggers.forEach((tr, i) => tr.addEventListener('click', () => open(i)));
    lb.querySelector('.lb-close')?.addEventListener('click', close);
    lb.querySelector('.lb-prev')?.addEventListener('click', (e) => { e.stopPropagation(); step(-1); });
    lb.querySelector('.lb-next')?.addEventListener('click', (e) => { e.stopPropagation(); step(1); });
    lb.addEventListener('click', (e) => { if (e.target === lb || e.target === lbImg.parentElement) close(); });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') step(-1);
      else if (e.key === 'ArrowRight') step(1);
    });
  }
</script>
