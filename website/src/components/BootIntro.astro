---
/* Animated boot sequence: monitor power-on -> GRUB (with btrfs snapshots) ->
   Plymouth brass splash -> desktop reveal. Uses the real OS theme assets.
   Plays once per session, skippable, disabled for prefers-reduced-motion. */
import { type Lang } from '../i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
const it = lang === 'it';
const L = {
  grubTitle: it ? 'Avvio di SkillFishOS in' : 'Booting SkillFishOS in',
  e_main: 'SkillFishOS',
  e_adv: it ? 'Opzioni avanzate' : 'Advanced options',
  e_snap: it ? 'Snapshot di sistema (btrfs)' : 'System snapshots (btrfs)',
  e_uefi: it ? 'Impostazioni firmware UEFI' : 'UEFI firmware settings',
  snapHint: it ? 'Ripristina qualsiasi aggiornamento in pochi secondi' : 'Roll back any update in seconds',
  skip: it ? 'Salta intro' : 'Skip intro',
};
/* real snapper snapshots (pre/post apt) read from the live system */
const snaps = [
  { n: 29, t: '2026-06-06 02:12', d: 'apt' },
  { n: 27, t: '2026-06-06 02:07', d: 'apt' },
  { n: 25, t: '2026-06-06 02:06', d: 'apt' },
  { n: 23, t: '2026-06-06 02:06', d: 'apt' },
];
---
<div id="bootintro" class="bi" aria-hidden="true">
  <!-- 1. monitor power-on -->
  <div class="bi-crt"></div>

  <!-- 2. GRUB -->
  <div class="bi-grub">
    <div class="bi-grub-inner">
      <div class="bi-grub-head">GNU GRUB&nbsp;&nbsp;version 2.12</div>
      <ul class="bi-menu">
        <li data-i="0">{L.e_main}</li>
        <li data-i="1">{L.e_adv}</li>
        <li data-i="2" class="bi-snaprow">
          <span>{L.e_snap}</span>
          <div class="bi-snaps">
            {snaps.map((s) => (
              <div class="bi-snap"><b>@{s.n}</b> · {s.t} · {s.d}</div>
            ))}
            <div class="bi-snap-hint">↻ {L.snapHint}</div>
          </div>
        </li>
        <li data-i="3">{L.e_uefi}</li>
      </ul>
      <div class="bi-count">{L.grubTitle} <span id="bi-sec">3</span>s</div>
    </div>
  </div>

  <!-- 3. Plymouth -->
  <div class="bi-ply">
    <div class="bi-bar"><div class="bi-bar-fill"></div></div>
  </div>

  <!-- 4. desktop reveal -->
  <div class="bi-desk"></div>

  <button class="bi-skip" type="button">{L.skip} ✕</button>
</div>

<style define:vars={{ grub: 'url(/img/boot/grub-bg.png)', ply: 'url(/img/boot/plymouth-splash.png)', desk: 'url(/img/desktop.jpg)' }}>
  .bi{position:fixed;inset:0;z-index:9999;background:#000;overflow:hidden;
      font-family:'DejaVu Sans','Inter',sans-serif}
  .bi.done{opacity:0;visibility:hidden;transition:opacity .6s ease .1s,visibility 0s .7s}

  /* layers hidden by default, shown per phase */
  .bi-crt,.bi-grub,.bi-ply,.bi-desk{position:absolute;inset:0;opacity:0}

  /* CRT power-on */
  .bi-crt{background:#0b100b}
  .bi.p-crt .bi-crt{animation:crt .9s ease forwards}
  @keyframes crt{
    0%{opacity:1;transform:scaleY(.004) scaleX(1);filter:brightness(3)}
    8%{transform:scaleY(.004) scaleX(1);filter:brightness(4)}
    28%{transform:scaleY(1) scaleX(1);filter:brightness(1.8)}
    100%{opacity:1;transform:scaleY(1);filter:brightness(1)}
  }

  /* GRUB */
  .bi-grub{background:#0b100b var(--grub) center/cover no-repeat}
  .bi.p-grub .bi-grub{opacity:1;transition:opacity .25s}
  .bi-grub-inner{position:absolute;left:50%;top:54%;transform:translate(-50%,-50%);
      width:min(640px,82vw);color:#cbb98f}
  .bi-grub-head{font-size:.8rem;letter-spacing:.04em;color:#9c8c63;margin-bottom:14px;text-align:center;opacity:.8}
  .bi-menu{list-style:none;font-size:clamp(1rem,2.4vw,1.35rem)}
  .bi-menu li{padding:9px 18px;border-radius:4px;color:#cbb98f;position:relative;transition:background .12s}
  .bi-menu li.sel{color:#f6e2a0;font-weight:700;background:rgba(246,226,160,.10);
      box-shadow:inset 0 0 0 1px rgba(246,226,160,.22)}
  .bi-snaps{max-height:0;overflow:hidden;opacity:0;transition:max-height .4s ease,opacity .3s;
      margin:0 6px;padding-left:18px;border-left:2px solid rgba(246,226,160,.25)}
  .bi-snaprow.open .bi-snaps{max-height:200px;opacity:1;margin-top:8px}
  .bi-snap{font-size:.82rem;color:#bda874;font-weight:400;padding:4px 0}
  .bi-snap b{color:#e8c878}
  .bi-snap-hint{font-size:.8rem;color:#9ccf6a;padding:6px 0 2px}
  .bi-count{margin-top:20px;text-align:center;color:#9c8c63;font-size:.86rem}
  #bi-sec{color:#e8c878;font-weight:700}

  /* Plymouth */
  .bi-ply{background:#0b100b var(--ply) center/cover no-repeat}
  .bi.p-ply .bi-ply{opacity:1;transition:opacity .35s}
  .bi-bar{position:absolute;left:50%;top:62%;transform:translateX(-50%);
      width:min(460px,60vw);height:6px;border-radius:4px;background:rgba(216,168,73,.14);
      box-shadow:inset 0 0 0 1px rgba(216,168,73,.22)}
  .bi-bar-fill{height:100%;width:0;border-radius:4px;
      background:linear-gradient(90deg,#b9722f,#d8a849 60%,#e8c878)}
  .bi.p-ply .bi-bar-fill{animation:fill 2.4s cubic-bezier(.5,.05,.3,1) forwards}
  @keyframes fill{0%{width:0}30%{width:34%}55%{width:52%}100%{width:100%}}

  /* desktop reveal */
  .bi-desk{background:#0b100b var(--desk) center/cover no-repeat;transform:scale(1.06)}
  .bi.p-desk .bi-desk{opacity:1;transform:scale(1);transition:opacity .7s ease,transform 1.4s ease}

  /* subtle scanlines + vignette over everything for the CRT feel */
  .bi::after{content:"";position:absolute;inset:0;pointer-events:none;
      background:linear-gradient(rgba(0,0,0,0) 50%,rgba(0,0,0,.10) 51%) 0/100% 3px;
      box-shadow:inset 0 0 220px rgba(0,0,0,.55)}
  .bi.p-desk::after{opacity:0;transition:opacity .6s}

  .bi-skip{position:absolute;right:18px;bottom:16px;z-index:2;cursor:pointer;
      background:rgba(12,10,6,.6);border:1px solid rgba(216,168,73,.3);color:#cbb98f;
      padding:7px 14px;border-radius:999px;font-size:.8rem;font-family:'Inter',sans-serif;
      backdrop-filter:blur(6px);transition:.2s}
  .bi-skip:hover{color:#f6e2a0;border-color:rgba(246,226,160,.55)}

  /* --- mobile / portrait tuning --- */
  @media(max-width:640px){
    /* show the WHOLE splash (fish + SkillFishOS plate) instead of a cropped center strip;
       the #0b100b backdrop matches the splash so the letterbox is invisible */
    .bi-ply{background-size:contain}
    .bi-bar{top:74%;width:72vw;height:7px}
    .bi-grub-inner{width:90vw;top:50%}
    .bi-menu{font-size:1.05rem}
    .bi-menu li{padding:8px 12px}
    .bi-grub-head{font-size:.74rem;margin-bottom:10px}
    .bi-snap{font-size:.74rem}
    .bi-snap-hint{font-size:.74rem}
    .bi-count{font-size:.8rem;margin-top:16px}
    .bi-skip{right:12px;bottom:12px;padding:8px 14px;font-size:.82rem}
  }

  @media(prefers-reduced-motion:reduce){.bi:not(.force){display:none}}
</style>

<script>
  (function () {
    const el = document.getElementById('bootintro');
    if (!el) return;
    // ?boot in the URL force-plays it (replay link); otherwise once/session + reduced-motion aware
    const force = new URLSearchParams(location.search).has('boot');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (force) el.classList.add('force');
    else if (reduce || sessionStorage.getItem('sfo-boot') === '1') { el.remove(); return; }

    document.body.style.overflow = 'hidden';
    const sel = (i) => {
      el.querySelectorAll('.bi-menu li').forEach((li) => li.classList.remove('sel'));
      const li = el.querySelector('.bi-menu li[data-i="' + i + '"]');
      if (li) li.classList.add('sel');
    };
    const timers = [];
    const at = (ms, fn) => timers.push(setTimeout(fn, ms));

    function finish() {
      timers.forEach(clearTimeout);
      sessionStorage.setItem('sfo-boot', '1');
      el.classList.add('done');
      document.body.style.overflow = '';
      setTimeout(() => el.remove(), 800);
    }
    el.querySelector('.bi-skip')?.addEventListener('click', finish);

    // ---- timeline ----
    const snaprow = el.querySelector('.bi-snaprow');
    const secEl = el.querySelector('#bi-sec');
    el.classList.add('p-crt');
    at(900, () => { el.classList.remove('p-crt'); el.classList.add('p-grub'); sel(0); });
    // grub: highlight the snapshots entry + open the submenu, then settle on boot
    at(1500, () => { sel(2); snaprow && snaprow.classList.add('open'); });
    at(3000, () => { snaprow && snaprow.classList.remove('open'); sel(0); });
    // count down 3 -> 2 -> 1
    [2, 1].forEach((v, k) => at(1900 + k * 750, () => { if (secEl) secEl.textContent = String(v); }));
    // plymouth
    at(3600, () => { el.classList.remove('p-grub'); el.classList.add('p-ply'); });
    // desktop
    at(6100, () => { el.classList.remove('p-ply'); el.classList.add('p-desk'); });
    at(7600, finish);
  })();
</script>
