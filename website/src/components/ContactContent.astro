---
import { t, localePath, SITE, type Lang } from '../i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const ret = localePath('/contact', lang);
const issues = `${SITE.github}/issues`;
---
<section class="hero" style="padding-bottom:24px">
  <div class="wrap">
    <div class="soon"><span class="dot"></span><span>{t('ct.eye', lang)}</span></div>
    <h1 style="font-size:clamp(2rem,5vw,3.2rem)">{t('ct.h2', lang)}</h1>
    <p class="sub">{t('ct.sub', lang)}</p>
  </div>
</section>

<section class="features" style="padding-top:10px">
  <div class="wrap" style="max-width:720px">
    <div id="ct-banner" class="ct-banner" hidden></div>
    <form class="ct-form" method="POST" action="/contact.php">
      <input type="hidden" name="ret" value={ret} />
      <input type="hidden" name="lang" value={lang} />
      <!-- honeypot: hidden from humans, bots fill it -->
      <div class="ct-hp" aria-hidden="true">
        <label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
      </div>

      <div class="ct-row">
        <label class="ct-field">
          <span>{t('ct.f.name', lang)}</span>
          <input type="text" name="name" required maxlength="80" />
        </label>
        <label class="ct-field">
          <span>{t('ct.f.email', lang)}</span>
          <input type="email" name="email" required maxlength="120" />
        </label>
      </div>

      <label class="ct-field">
        <span>{t('ct.f.type', lang)}</span>
        <select name="type">
          <option value="support">{t('ct.type.support', lang)}</option>
          <option value="info">{t('ct.type.info', lang)}</option>
          <option value="other">{t('ct.type.other', lang)}</option>
        </select>
      </label>

      <label class="ct-field">
        <span>{t('ct.f.msg', lang)}</span>
        <textarea name="message" rows="6" required maxlength="4000"></textarea>
      </label>

      <label class="ct-field ct-captcha">
        <span>{t('ct.f.captcha', lang)} <strong id="ct-q">…</strong>?</span>
        <input type="text" name="captcha" required inputmode="numeric" autocomplete="off" style="max-width:140px" />
      </label>

      <button type="submit" class="btn btn-primary">{t('ct.send', lang)}</button>
      <p class="ct-privacy">{t('ct.privacy', lang)}</p>
    </form>
  </div>
</section>

<script
  define:vars={{
    okMsg: t('ct.ok', lang),
    errCaptcha: t('ct.err.captcha', lang),
    errFields: t('ct.err.fields', lang),
    errSend: t('ct.err.send', lang),
    errGeneric: t('ct.err.generic', lang),
    issues,
  }}
>
  // Load the captcha challenge (answer is stored server-side in the PHP session).
  fetch('/captcha.php', { credentials: 'same-origin', cache: 'no-store' })
    .then((r) => r.json())
    .then((d) => { const q = document.getElementById('ct-q'); if (q && d && d.q) q.textContent = d.q; })
    .catch(() => {});

  // Show success/error banner based on the redirect query string from contact.php.
  const params = new URLSearchParams(location.search);
  const banner = document.getElementById('ct-banner');
  function show(msg, ok) {
    if (!banner) return;
    banner.textContent = msg;
    banner.classList.toggle('ok', ok);
    banner.classList.toggle('err', !ok);
    banner.hidden = false;
    banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  if (params.get('sent') === '1') show(okMsg, true);
  else if (params.has('error')) {
    const e = params.get('error');
    show(e === 'captcha' ? errCaptcha : e === 'fields' ? errFields : e === 'send' ? errSend : errGeneric, false);
  }
</script>
