---
import { t, localePath, type Lang } from '../i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const specs = [
  { t: 'hwp.cpu.t', d: 'hwp.cpu.d' },
  { t: 'hwp.gpu.t', d: 'hwp.gpu.d' },
  { t: 'hwp.mem.t', d: 'hwp.mem.d' },
  { t: 'hwp.perf.t', d: 'hwp.perf.d' },
];
const quirks = [
  { t: 'hwp.q1.t', d: 'hwp.q1.d' },
  { t: 'hwp.q2.t', d: 'hwp.q2.d' },
  { t: 'hwp.q3.t', d: 'hwp.q3.d' },
  { t: 'hwp.q4.t', d: 'hwp.q4.d' },
];
// vkpeak FP32-scalar (GFLOPS), measured on the same BC-250.
const BMAX = 12000;
const bars = [
  { l: 'bm.bar1', v: 6141, hl: false },
  { l: 'bm.bar2', v: 6868, hl: false },
  { l: 'bm.bar3', v: 11329, hl: true },
];
const bstats = [
  { v: '1.84×', l: 'bm.s1.l' },
  { v: '11329', l: 'bm.s2.l' },
  { v: '22685', l: 'bm.s3.l' },
  { v: '45495', l: 'bm.s4.l' },
];
// Black Myth: Wukong (1080p) — averages measured from ~4 min of in-game telemetry.
const wkstats = [
  { v: '2230 MHz', l: 'wk.l.gpu' },
  { v: '~84 °C', l: 'wk.l.gpuc' },
  { v: '~150 W', l: 'wk.l.pwr' },
  { v: '3.9 GHz', l: 'wk.l.cpu' },
  { v: '4.5 GB', l: 'wk.l.vram' },
  { v: 'auto', l: 'wk.l.fan' },
];
// Gaming benchmark headline cards + GPU comparisons (Unigine leaderboards).
const gbench = [
  { v: 'gb.wk.v', l: 'gb.wk.l' },
  { v: 'gb.hv.v', l: 'gb.hv.l' },
  { v: 'gb.sp.v', l: 'gb.sp.l' },
];
const cmpOS = { max: 6000, bars: [
  { l: 'cmp.os.b1', v: 5513, hl: true },
  { l: 'cmp.os.b2', v: 4102, hl: false },
] };
const cmpGPU = { max: 16500, bars: [
  { l: 'cmp.gpu.b1', v: 12938, hl: true },
  { l: 'cmp.gpu.b2', v: 12454, hl: false },
  { l: 'cmp.gpu.b3', v: 15806, hl: false },
] };
---
<section class="hero" style="padding-bottom:30px">
  <div class="wrap">
    <div class="soon"><span class="dot"></span><span>{t('hwp.eye', lang)}</span></div>
    <h1 style="font-size:clamp(2rem,5vw,3.4rem)" set:html={t('hwp.h2', lang)} />
    <p class="sub">{t('hwp.sub', lang)}</p>
  </div>
</section>

<section class="specs" style="padding-top:10px">
  <div class="wrap">
    <div class="chips">
      <div class="chip"><div class="big">6× Zen 2</div><div class="lbl">CPU "Oberon"</div></div>
      <div class="chip"><div class="big">RDNA 2</div><div class="lbl">40 CU · gfx1013</div></div>
      <div class="chip"><div class="big">~11 TFLOPS</div><div class="lbl">FP32 · Vulkan</div></div>
      <div class="chip"><div class="big">16 GB</div><div class="lbl">GDDR6 UMA</div></div>
    </div>
  </div>
</section>

<section class="features" style="padding-top:30px">
  <div class="wrap">
    <div class="sec-head"><div class="eyebrow">{t('hwp.specs.h', lang)}</div></div>
    <div class="grid">
      {specs.map((s) => (
        <div class="card"><h3>{t(s.t, lang)}</h3><p set:html={t(s.d, lang)} /></div>
      ))}
    </div>
  </div>
</section>

<section class="features" style="padding-top:10px">
  <div class="wrap" style="max-width:880px">
    <div class="sec-head"><div class="eyebrow">⚙️ Tuning</div><h2>{t('oc.h', lang)}</h2><p set:html={t('oc.sub', lang)} /></div>
    <div class="chips">
      <div class="chip"><div class="big">{t('oc.cpu.v', lang)}</div><div class="lbl" set:html={t('oc.cpu.l', lang)} /></div>
      <div class="chip"><div class="big">{t('oc.uv.v', lang)}</div><div class="lbl" set:html={t('oc.uv.l', lang)} /></div>
      <div class="chip"><div class="big">{t('oc.gpu.v', lang)}</div><div class="lbl" set:html={t('oc.gpu.l', lang)} /></div>
      <div class="chip"><div class="big">{t('oc.cap.v', lang)}</div><div class="lbl" set:html={t('oc.cap.l', lang)} /></div>
    </div>
    <p class="bm-note" set:html={t('oc.note', lang)} />
  </div>
</section>

<section class="features" style="padding-top:10px">
  <div class="wrap" style="max-width:880px">
    <div class="sec-head"><div class="eyebrow">Benchmark</div><h2>{t('bm.h', lang)}</h2><p set:html={t('bm.sub', lang)} /></div>
    <div class="bm-chart">
      {bars.map((b) => (
        <div class="bm-row">
          <div class="bm-label">{t(b.l, lang)}</div>
          <div class="bm-track">
            <div class={`bm-fill ${b.hl ? 'hl' : ''}`} style={`width:${Math.round((b.v / BMAX) * 100)}%`}>
              <span class="bm-val">{b.v.toLocaleString('it-IT')}</span>
            </div>
          </div>
        </div>
      ))}
      <div class="bm-axis">{t('bm.unit', lang)}</div>
    </div>
    <div class="chips" style="margin-top:36px">
      {bstats.map((s) => (
        <div class="chip"><div class="big">{s.v}</div><div class="lbl">{t(s.l, lang)}</div></div>
      ))}
    </div>
    <p class="bm-note" set:html={t('bm.note', lang)} />
    <p class="bm-note" style="opacity:.8">{t('bm.src', lang)} <a href={localePath('/docs/gpu-overclock', lang)}>{t('bm.gpulink', lang)}</a> · <a href={localePath('/docs/kernel', lang)}>kernel</a>.</p>

    <h3 style="text-align:center;margin:48px 0 6px;color:var(--gold-lt);font-size:1.2rem">🎮 {t('wk.h', lang)}</h3>
    <div class="chips" style="margin-top:18px">
      {wkstats.map((s) => (
        <div class="chip"><div class="big">{s.v}</div><div class="lbl">{t(s.l, lang)}</div></div>
      ))}
    </div>
    <p class="bm-note" set:html={t('wk.note', lang)} />
  </div>
</section>

<section class="features" style="padding-top:0">
  <div class="wrap" style="max-width:920px">
    <div class="sec-head"><div class="eyebrow">🎮 Gaming</div><h2>{t('gb.h', lang)}</h2><p set:html={t('gb.sub', lang)} /></div>
    <div class="chips">
      {gbench.map((g) => (
        <div class="chip"><div class="big">{t(g.v, lang)}</div><div class="lbl" set:html={t(g.l, lang)} /></div>
      ))}
    </div>

    <h3 style="text-align:center;margin:54px 0 6px;color:var(--gold-lt);font-size:1.25rem">⚡ {t('cmp.os.h', lang)}</h3>
    <p style="text-align:center;color:var(--muted);max-width:680px;margin:0 auto 22px" set:html={t('cmp.os.sub', lang)} />
    <div class="bm-chart">
      {cmpOS.bars.map((b) => (
        <div class="bm-row">
          <div class="bm-label" set:html={t(b.l, lang)} />
          <div class="bm-track"><div class={`bm-fill ${b.hl ? 'hl' : ''}`} style={`width:${Math.round((b.v / cmpOS.max) * 100)}%`}><span class="bm-val">{b.v.toLocaleString('it-IT')}</span></div></div>
        </div>
      ))}
      <div class="bm-axis">{t('cmp.axis', lang)} · Extreme</div>
    </div>
    <p class="bm-note" set:html={t('cmp.os.note', lang)} />

    <h3 style="text-align:center;margin:54px 0 6px;color:var(--gold-lt);font-size:1.25rem">🏆 {t('cmp.gpu.h', lang)}</h3>
    <p style="text-align:center;color:var(--muted);max-width:680px;margin:0 auto 22px" set:html={t('cmp.gpu.sub', lang)} />
    <div class="bm-chart">
      {cmpGPU.bars.map((b) => (
        <div class="bm-row">
          <div class="bm-label" set:html={t(b.l, lang)} />
          <div class="bm-track"><div class={`bm-fill ${b.hl ? 'hl' : ''}`} style={`width:${Math.round((b.v / cmpGPU.max) * 100)}%`}><span class="bm-val">{b.v.toLocaleString('it-IT')}</span></div></div>
        </div>
      ))}
      <div class="bm-axis">{t('cmp.axis', lang)} · High</div>
    </div>
    <p class="bm-note" set:html={t('cmp.gpu.note', lang)} />
  </div>
</section>

<section class="showcase">
  <div class="wrap">
    <div class="sec-head"><h2>{t('hwp.quirks.h', lang)}</h2></div>
    <div class="grid">
      {quirks.map((q) => (
        <div class="card"><h3>{t(q.t, lang)}</h3><p set:html={t(q.d, lang)} /></div>
      ))}
    </div>
    <div style="text-align:center;margin-top:40px">
      <a class="btn btn-ghost" href={localePath('/docs/hardware-bc250', lang)}>{t('hwp.cta', lang)}</a>
    </div>
  </div>
</section>
