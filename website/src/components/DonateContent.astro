---
import { t, SITE, type Lang } from '../i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const amtLabel: Record<string, string> = { '1': '☕', '2': '☕☕', '5': '⚙️', '10': '🔧' };
const amtSub: Record<string, Record<Lang, string>> = {
  '1': { it: 'un sorso', en: 'a sip' },
  '2': { it: 'un caffè', en: 'a coffee' },
  '5': { it: 'un dissipatore', en: 'a heatsink' },
  '10': { it: 'verso una scheda', en: 'toward a board' },
};
const uses = [
  { i: '🧩', t: 'don.u1.t', d: 'don.u1.d' },
  { i: '❄️', t: 'don.u2.t', d: 'don.u2.d' },
  { i: '🌐', t: 'don.u3.t', d: 'don.u3.d' },
  { i: '⏱️', t: 'don.u4.t', d: 'don.u4.d' },
];
const comm = [
  { i: '⭐', t: 'comm.star.t', d: 'comm.star.d', btn: 'comm.star.btn', href: SITE.ghStar },
  { i: '★', t: 'comm.review.t', d: 'comm.review.d', btn: 'comm.review.btn', href: SITE.reviews },
  { i: '💡', t: 'comm.idea.t', d: 'comm.idea.d', btn: 'comm.idea.btn', href: SITE.discussions },
];
---
<section class="hero" style="padding-bottom:24px">
  <div class="wrap">
    <div class="soon"><span class="dot"></span><span>{t('don.eye', lang)}</span></div>
    <h1 style="font-size:clamp(2.1rem,5.5vw,3.6rem)" set:html={t('don.h2', lang)} />
    <p class="sub" style="max-width:680px" set:html={t('don.sub', lang)} />
  </div>
</section>

<!-- The honest story -->
<section class="intro" style="padding:30px 0 60px">
  <div class="wrap">
    <div class="why-box">
      <h2>{t('don.why.h', lang)}</h2>
      <p set:html={t('don.why.p1', lang)} />
      <p set:html={t('don.why.p2', lang)} />
    </div>
  </div>
</section>

<!-- The donate action -->
<section class="features" style="padding-top:0">
  <div class="wrap">
    <div class="donate-card">
      <div class="donate-give">
        <h2 style="font-size:clamp(1.7rem,4vw,2.4rem)">{t('don.give.h', lang)}</h2>
        <p class="muted" set:html={t('don.give.p', lang)} />
        <div class="amounts">
          {SITE.donateAmounts.map((a) => (
            <a class="amt" href={`${SITE.donateUrl}/${a}EUR`} target="_blank" rel="noopener">
              <span class="amt-ico">{amtLabel[a] ?? '☕'}</span>
              <span class="amt-eur">€{a}</span>
              <span class="amt-sub">{amtSub[a]?.[lang] ?? ''}</span>
            </a>
          ))}
        </div>
        <a class="btn btn-ghost amt-custom" href={SITE.donateUrl} target="_blank" rel="noopener">♾️ {t('don.give.custom', lang)} →</a>
        <p class="muted note" set:html={t('don.give.note', lang)} />
      </div>
      <div class="donate-qr">
        <span class="qr-or">{t('don.give.or', lang)}</span>
        <a href={SITE.donateUrl} target="_blank" rel="noopener" aria-label={t('don.give.scan', lang)}>
          <img src={SITE.donateQr} alt="QR PayPal" width="280" height="310" loading="lazy" />
        </a>
        <span class="qr-cap">{t('don.give.scan', lang)}</span>
      </div>
    </div>
    <p class="thanks" set:html={t('don.thanks', lang)} />
  </div>
</section>

<!-- Where the money goes -->
<section class="features" style="padding-top:10px">
  <div class="wrap">
    <div class="sec-head"><div class="eyebrow">{t('don.use.h', lang)}</div><p>{t('don.use.sub', lang)}</p></div>
    <div class="grid">
      {uses.map((u) => (
        <div class="card"><span class="ico">{u.i}</span><h3>{t(u.t, lang)}</h3><p>{t(u.d, lang)}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- Free ways to help -->
<section class="showcase" style="padding:60px 0">
  <div class="wrap">
    <div class="sec-head"><h2>{t('comm.h', lang)}</h2><p>{t('comm.sub', lang)}</p></div>
    <div class="grid">
      {comm.map((c) => (
        <div class="card comm-card">
          <span class="ico">{c.i}</span>
          <h3>{t(c.t, lang)}</h3>
          <p>{t(c.d, lang)}</p>
          <a class="btn btn-ghost" href={c.href} target="_blank" rel="noopener">{t(c.btn, lang)}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-box{max-width:820px;margin:0 auto;background:linear-gradient(160deg,var(--panel),var(--panel2));border:1px solid var(--line);border-radius:20px;padding:clamp(26px,4vw,44px)}
  .why-box h2{font-size:clamp(1.5rem,3.5vw,2.1rem);margin-bottom:18px;color:var(--gold-lt)}
  .why-box p{color:var(--muted);font-size:1.05rem;margin-bottom:14px}
  .why-box strong{color:var(--cream)}

  .donate-card{display:grid;grid-template-columns:1.25fr .9fr;gap:clamp(24px,4vw,48px);align-items:center;
    background:linear-gradient(135deg,rgba(216,168,73,.14),rgba(185,114,47,.07));border:1px solid rgba(216,168,73,.4);
    border-radius:26px;padding:clamp(28px,4vw,48px);box-shadow:0 24px 70px rgba(0,0,0,.45)}
  .donate-give h2{color:var(--cream)}
  .donate-give .muted{color:var(--muted);margin:12px 0 22px;max-width:48ch}
  .donate-give .note{font-size:.9rem;margin-top:20px;margin-bottom:0}
  .amounts{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
  .amt{display:flex;flex-direction:column;align-items:center;gap:3px;padding:16px 8px;border-radius:14px;
    background:linear-gradient(160deg,var(--panel),var(--panel2));border:1px solid var(--line);
    transition:transform .15s,border-color .25s,box-shadow .25s}
  .amt:hover{transform:translateY(-3px);border-color:rgba(216,168,73,.6);box-shadow:0 12px 28px rgba(0,0,0,.4)}
  .amt-ico{font-size:1.15rem;line-height:1}
  .amt-eur{font-family:'Sora','Inter',sans-serif;font-weight:800;font-size:1.5rem;color:var(--gold-lt)}
  .amt-sub{font-size:.72rem;color:var(--muted);text-align:center}
  .amt-custom{margin-top:14px;display:inline-block}

  .donate-qr{display:flex;flex-direction:column;align-items:center;gap:10px;text-align:center}
  .qr-or{font-size:.82rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}
  .donate-qr img{width:260px;max-width:72vw;height:auto;border-radius:18px;background:#fff;padding:10px;
    box-shadow:0 16px 40px rgba(0,0,0,.4);border:1px solid rgba(216,168,73,.3);transition:transform .2s}
  .donate-qr a:hover img{transform:scale(1.03)}
  .qr-cap{font-size:.88rem;color:var(--muted)}
  .qr-cap strong{color:var(--gold-lt)}

  .thanks{text-align:center;color:var(--gold-lt);font-size:1.1rem;font-weight:600;margin-top:34px}

  .comm-card{display:flex;flex-direction:column;align-items:flex-start}
  .comm-card p{flex:1;margin-bottom:18px}
  .comm-card .btn{align-self:flex-start}

  @media(max-width:760px){
    .donate-card{grid-template-columns:1fr;text-align:center}
    .donate-give .muted{margin-left:auto;margin-right:auto}
    .donate-qr{order:-1}
    .amounts{grid-template-columns:repeat(2,1fr)}
    .amt-custom{display:block}
  }
</style>
