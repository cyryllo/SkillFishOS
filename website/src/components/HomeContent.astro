---
import { t, localePath, type Lang } from '../i18n';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const dl = localePath('/download', lang);
---
<a id="top"></a>
<section class="hero">
  <div class="wrap">
    <div class="soon"><span class="dot"></span><span>{t('hero.soon', lang)}</span></div>
    <img class="hero-logo" src="/img/logo.png" alt="SkillFishOs logo" />
    <h1>SkillFish<span class="gold-text">Os</span></h1>
    <p class="tag" set:html={t('hero.tag', lang)} />
    <p class="sub" set:html={t('hero.sub', lang)} />
    <div class="hero-btns">
      <a class="btn btn-primary" href="#screenshot">{t('hero.btn1', lang)}</a>
      <a class="btn btn-ghost" href="#funzioni">{t('hero.btn2', lang)}</a>
    </div>
    <div class="pill"><img src="/img/logo.png" alt="" style="width:22px;height:22px;vertical-align:-6px;margin-right:4px" /> <span set:html={t('hero.pill', lang)} /></div>
    <div class="hero-shot"><img src="/img/desktop.jpg" alt="Desktop SkillFishOs steampunk con HUD di sistema" /></div>
  </div>
</section>

<section class="intro" id="cose">
  <div class="wrap intro-grid">
    <div>
      <div class="eyebrow">{t('intro.eye', lang)}</div>
      <h2 set:html={t('intro.h2', lang)} />
      <p set:html={t('intro.p1', lang)} />
      <p set:html={t('intro.p2', lang)} />
    </div>
    <div><img src="/img/about.jpg" alt="Pagina informazioni di SkillFishOs" /></div>
  </div>
</section>

<section class="features" id="funzioni">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow">{t('feat.eye', lang)}</div>
      <h2>{t('feat.h2', lang)}</h2>
      <p>{t('feat.sub', lang)}</p>
    </div>
    <div class="grid">
      <div class="card"><span class="ico">🎮</span><h3>{t('f1.t', lang)}</h3><p set:html={t('f1.d', lang)} /></div>
      <div class="card"><span class="ico">⚙️</span><h3>{t('f2.t', lang)}</h3><p set:html={t('f2.d', lang)} /></div>
      <div class="card"><span class="ico">✅</span><h3>{t('f3.t', lang)}</h3><p set:html={t('f3.d', lang)} /></div>
      <div class="card"><span class="ico"><img src="/img/logo.png" alt="" style="width:34px;height:34px;vertical-align:middle" /></span><h3>{t('f4.t', lang)}</h3><p set:html={t('f4.d', lang)} /></div>
      <div class="card"><span class="ico">📸</span><h3>{t('f5.t', lang)}</h3><p set:html={t('f5.d', lang)} /></div>
      <div class="card"><span class="ico">🧠</span><h3>{t('f6.t', lang)}</h3><p set:html={t('f6.d', lang)} /></div>
    </div>
  </div>
</section>

<section class="showcase" id="screenshot">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow">{t('show.eye', lang)}</div>
      <h2>{t('show.h2', lang)}</h2>
    </div>
    <div class="shots">
      <div class="shot">
        <img src="/img/desktop.jpg" alt="Desktop steampunk con HUD" />
        <div class="shot-txt"><h3>{t('s1.t', lang)}</h3><p set:html={t('s1.d', lang)} /></div>
      </div>
      <div class="shot">
        <img src="/img/emudeck.jpg" alt="EmuDeck su SkillFishOs" />
        <div class="shot-txt"><h3>{t('s2.t', lang)}</h3><p set:html={t('s2.d', lang)} /></div>
      </div>
      <div class="shot tall">
        <img src="/img/ai-panel.jpg" alt="Pannello AI di SkillFishOs" />
        <div class="shot-txt"><h3>{t('s4.t', lang)}</h3><p set:html={t('s4.d', lang)} /></div>
      </div>
      <div class="shot tall">
        <img src="/img/tuner.jpg" alt="Tuner di SkillFishOs" />
        <div class="shot-txt"><h3>{t('s5.t', lang)}</h3><p set:html={t('s5.d', lang)} /></div>
      </div>
    </div>
  </div>
</section>

<section class="specs" id="hardware">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow">{t('hw.eye', lang)}</div>
      <h2>{t('hw.h2', lang)}</h2>
      <p>{t('hw.sub', lang)}</p>
    </div>
    <div class="chips">
      <div class="chip"><div class="big">6× Zen 2</div><div class="lbl">{t('hw.c1', lang)}</div></div>
      <div class="chip"><div class="big">RDNA 2</div><div class="lbl">{t('hw.c2', lang)}</div></div>
      <div class="chip"><div class="big">~11 TFLOPS</div><div class="lbl">{t('hw.c3', lang)}</div></div>
      <div class="chip"><div class="big">16 GB</div><div class="lbl">{t('hw.c4', lang)}</div></div>
    </div>
  </div>
</section>

<section class="cta">
  <div class="wrap">
    <div class="cta-box">
      <div class="eyebrow">SkillFishOs</div>
      <h2 set:html={t('cta.h2', lang)} />
      <p set:html={t('cta.p', lang)} />
      <a class="btn btn-primary" href={dl} set:html={t('cta.btn', lang)} />
    </div>
  </div>
</section>
