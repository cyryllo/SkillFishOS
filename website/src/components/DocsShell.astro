---
import type { MarkdownHeading } from 'astro';
import { localePath, type Lang } from '../i18n';

interface DocEntry {
  id: string;
  data: { title: string; description?: string; group: string; order: number };
}
interface Props {
  lang: Lang;
  entries: DocEntry[];
  current: string;
  headings: MarkdownHeading[];
}
const { lang, entries, current, headings } = Astro.props;

// Group display order per language (group names come localized from frontmatter).
const groupOrder: Record<Lang, string[]> = {
  it: ['Introduzione', 'Installazione', 'Sistema', 'Uso', 'Riferimenti'],
  en: ['Introduction', 'Installation', 'System', 'Usage', 'Reference'],
};
const ui = {
  it: { onThisPage: 'In questa pagina', prev: 'Precedente', next: 'Successivo' },
  en: { onThisPage: 'On this page', prev: 'Previous', next: 'Next' },
};
const u = ui[lang];
const order = groupOrder[lang];
const gi = (g: string) => {
  const i = order.indexOf(g);
  return i === -1 ? 999 : i;
};
const sorted = [...entries].sort((a, b) =>
  gi(a.data.group) - gi(b.data.group) || a.data.order - b.data.order || a.data.title.localeCompare(b.data.title)
);

const groups: { name: string; items: DocEntry[] }[] = [];
for (const e of sorted) {
  let g = groups.find((x) => x.name === e.data.group);
  if (!g) { g = { name: e.data.group, items: [] }; groups.push(g); }
  g.items.push(e);
}

const flatIdx = sorted.findIndex((e) => e.id === current);
const prev = flatIdx > 0 ? sorted[flatIdx - 1] : null;
const next = flatIdx >= 0 && flatIdx < sorted.length - 1 ? sorted[flatIdx + 1] : null;
const cur = sorted[flatIdx];
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
<div class="docs">
  <aside class="docs-side">
    {groups.map((g) => (
      <div>
        <div class="grp">{g.name}</div>
        {g.items.map((it) => (
          <a href={localePath(`/docs/${it.id}`, lang)} class={it.id === current ? 'active' : ''}>{it.data.title}</a>
        ))}
      </div>
    ))}
  </aside>

  <article class="docs-main">
    <div class="eyebrow">{cur?.data.group}</div>
    <h1>{cur?.data.title}</h1>
    {cur?.data.description && <p class="docs-lead">{cur.data.description}</p>}
    <div class="docs-body">
      <slot />
    </div>

    <nav class="docs-nav">
      {prev ? (
        <a href={localePath(`/docs/${prev.id}`, lang)}>
          <div class="dir">← {u.prev}</div>
          <div class="ttl">{prev.data.title}</div>
        </a>
      ) : <span style="flex:1"></span>}
      {next ? (
        <a class="next" href={localePath(`/docs/${next.id}`, lang)}>
          <div class="dir">{u.next} →</div>
          <div class="ttl">{next.data.title}</div>
        </a>
      ) : <span style="flex:1"></span>}
    </nav>
  </article>

  {toc.length > 0 && (
    <aside class="docs-toc">
      <div class="tt">{u.onThisPage}</div>
      {toc.map((h) => (
        <a href={`#${h.slug}`} class={h.depth === 3 ? 'lvl3' : ''}>{h.text}</a>
      ))}
    </aside>
  )}
</div>
