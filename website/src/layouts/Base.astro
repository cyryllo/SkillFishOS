---
import { t, SITE, type Lang } from '../i18n';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  lang: Lang;
  page?: string;
  title?: string;
  description?: string;
}
const { lang, page = '/', title, description } = Astro.props;
const pageTitle = title ?? t('title', lang);
const pageDesc = description ?? t('meta.desc', lang);
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <meta property="og:title" content="SkillFishOS" />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:image" content={`${SITE.domain ? `https://${SITE.domain}` : ''}/img/desktop.jpg`} />
  <meta property="og:type" content="website" />
  <link rel="icon" href="/img/badge.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <Header lang={lang} page={page} />
  <slot />
  <Footer lang={lang} />
  <script is:inline>
    // SkillFishOS — anonymous, cookieless visit beacon (self-hosted /pulse.php).
    // Honours opt-out (localStorage 'sf_nostats') and Do-Not-Track.
    try {
      if (localStorage.getItem('sf_nostats') !== '1' && navigator.doNotTrack !== '1') {
        var body = 'p=' + encodeURIComponent(location.pathname) +
                   '&r=' + encodeURIComponent(document.referrer || '');
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/pulse.php',
            new Blob([body], { type: 'application/x-www-form-urlencoded' }));
        } else {
          var i = new Image(); i.src = '/pulse.php?' + body;
        }
      }
    } catch (e) {}
  </script>
</body>
</html>
