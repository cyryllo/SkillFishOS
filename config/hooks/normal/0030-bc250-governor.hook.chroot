#!/bin/bash
set -e

# The governor binary and config are placed via includes.chroot.
# Here we set up the systemd service.

# Verify binary exists (placed by includes.chroot)
if [ ! -x /usr/local/bin/cyan-skillfish-governor-smu ]; then
    echo "WARNING: cyan-skillfish-governor-smu not found — will try to fetch from GitHub"
    curl -fsSL https://github.com/Magnap/cyan-skillfish-governor/releases/latest/download/cyan-skillfish-governor-smu         -o /usr/local/bin/cyan-skillfish-governor-smu 2>/dev/null || true
    curl -fsSL https://github.com/Magnap/cyan-skillfish-governor/releases/latest/download/cyan-skillfish-performance-mode         -o /usr/local/bin/cyan-skillfish-performance-mode 2>/dev/null || true
    chmod +x /usr/local/bin/cyan-skillfish-governor-smu               /usr/local/bin/cyan-skillfish-performance-mode 2>/dev/null || true
fi

# Systemd service unit
cat > /etc/systemd/system/cyan-skillfish-governor.service << 'UNIT'
[Unit]
Description=Cyan Skillfish GPU Frequency Governor
Documentation=https://github.com/Magnap/cyan-skillfish-governor
After=graphical.target
Wants=graphical.target

[Service]
Type=simple
ExecStart=/usr/local/bin/cyan-skillfish-governor-smu
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=graphical.target
UNIT

systemctl enable cyan-skillfish-governor.service
echo "cyan-skillfish-governor service installed and enabled."
