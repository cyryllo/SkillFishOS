#!/bin/bash
set -e
echo "[i386] Enabling i386 multiarch for 32-bit gaming libraries"
dpkg --add-architecture i386
apt-get update
apt-get install -y --no-install-recommends \
    mesa-vulkan-drivers:i386 \
    libgl1-mesa-dri:i386 \
    libvulkan1:i386 \
    libgamemode0:i386 \
    libgamemodeauto0:i386 \
    mangohud:i386
echo "[i386] Done. Installed 32-bit Mesa/Vulkan/GameMode/MangoHud."
